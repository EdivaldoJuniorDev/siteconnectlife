# =============================================================================
# ConnectLife — variáveis de ambiente
# =============================================================================
# Copie este arquivo para .env.local e preencha com os valores reais.
# NUNCA commitar .env.local no git.

# -----------------------------------------------------------------------------
# Analytics / Tag Management
# -----------------------------------------------------------------------------
# ID do container Google Tag Manager (formato GTM-XXXXXXX).
# Deixe vazio para NÃO carregar GTM (dev local, preview, etc).
NEXT_PUBLIC_GTM_ID=

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://connectlife.com.br
